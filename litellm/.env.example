# LiteLLM proxy — holds all LLM API keys centrally
LITELLM_MASTER_KEY=sk-litellm-dev-key

# At least one LLM provider key is required
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Langfuse (auto-configured via Docker network)
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_HOST=http://langfuse:3000

# Presidio PII detection (auto-configured via Docker network)
PRESIDIO_ANALYZER_API_BASE=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_API_BASE=http://presidio-anonymizer:3000
