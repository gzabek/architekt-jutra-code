# LiteLLM proxy connection
# The proxy handles API keys, PII filtering (Presidio), and observability (Langfuse).
# LLM provider keys are configured in litellm/.env, not here.
LITELLM_API_KEY=sk-litellm-dev-key

# Note: Copy this file to .env.local and fill in the LiteLLM master key.
# .env.local is gitignored and will not be committed.
